{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sonar Room",
  "version": "0.1.0",
  "identifier": "app.sonar-room.desktop",
  "build": {
    "beforeDevCommand": "pnpm nx run desktop:dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm nx run desktop:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sonar Room",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
