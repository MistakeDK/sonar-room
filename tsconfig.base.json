{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "paths": {
      "@sonar-room/ui": [
        "libs/ui/src/index.ts"
      ],
      "@sonar-room/ui/styles.css": [
        "libs/ui/src/styles.css"
      ],
      "@sonar-room/ui/*": [
        "libs/ui/src/*"
      ]
    }
  }
}
