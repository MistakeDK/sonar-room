{
  "name": "ui",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/ui/src",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vue-tsc -p libs/ui/tsconfig.lib.json --noEmit && eslint \"libs/ui/src/**/*.{ts,vue}\""
      }
